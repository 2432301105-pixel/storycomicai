# Application
SC_APP_NAME=StoryComicAI API
SC_ENV=local
SC_DEBUG=true
SC_API_PREFIX=/v1

# Database
SC_DATABASE_URL=postgresql+psycopg://storycomicai:storycomicai@localhost:5432/storycomicai

# Redis / Celery
SC_REDIS_URL=redis://localhost:6379/0
SC_CELERY_BROKER_URL=redis://localhost:6379/0
SC_CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Auth
SC_AUTH_JWT_SECRET=change-me-for-local-dev
SC_AUTH_JWT_ALGORITHM=HS256
SC_AUTH_ACCESS_TOKEN_EXPIRE_MINUTES=120

# Apple Sign-In
SC_APPLE_CLIENT_ID=com.storycomicai.app
SC_APPLE_ISSUER=https://appleid.apple.com
SC_ALLOW_UNVERIFIED_APPLE_TOKEN_IN_LOCAL=true

# Storage
SC_STORAGE_PROVIDER=mock
SC_STORAGE_BUCKET=storycomicai-local
SC_STORAGE_REGION=
SC_STORAGE_ENDPOINT_URL=
SC_STORAGE_ACCESS_KEY_ID=
SC_STORAGE_SECRET_ACCESS_KEY=
SC_STORAGE_SESSION_TOKEN=
SC_STORAGE_PUBLIC_BASE_URL=
SC_STORAGE_PRESIGN_TTL_SECONDS=900
SC_EXPORT_ARTIFACT_DIR=/tmp/storycomicai-artifacts
SC_EXPORT_DOWNLOAD_TOKEN_TTL_SECONDS=3600

# AI Render Provider
SC_AI_RENDER_PROVIDER=mock
SC_AI_RENDER_PROVIDER_BASE_URL=
SC_AI_RENDER_PROVIDER_API_KEY=
SC_AI_RENDER_PROVIDER_MODEL_ID=storycomicai-panel-v1
SC_AI_RENDER_PROVIDER_ADAPTER_ID=
SC_AI_RENDER_PROVIDER_SUBMIT_PATH=/render/panels
SC_AI_RENDER_PROVIDER_STATUS_PATH_TEMPLATE=/render/jobs/{job_id}
SC_AI_RENDER_PROVIDER_POLL_INTERVAL_MS=1000
SC_AI_RENDER_PROVIDER_MAX_POLL_SECONDS=90
SC_AI_RENDER_PROVIDER_AUTH_HEADER=Authorization
SC_AI_RENDER_PROVIDER_AUTH_SCHEME=Bearer

# Runtime
SC_RUN_MIGRATIONS_ON_START=true
SC_WORKER_QUEUES=hero_preview,default
SC_WORKER_LOG_LEVEL=INFO
SC_WORKER_CONCURRENCY=2
SC_JOB_QUEUE_MODE=celery
