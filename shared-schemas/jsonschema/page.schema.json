{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.storycomicai.com/page.schema.json",
  "title": "Page",
  "type": "object",
  "required": ["page_no", "layout_type", "panels"],
  "properties": {
    "page_no": { "type": "integer", "minimum": 1 },
    "layout_type": { "type": "string" },
    "render_mode": { "type": "string", "enum": ["draft", "final"] },
    "panels": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./panel.schema.json" }
    },
    "status": {
      "type": "string",
      "enum": ["pending", "rendering", "ready", "failed"]
    }
  },
  "additionalProperties": false
}
