{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://schemas.storycomicai.com/story-plan.schema.json",
  "title": "StoryPlan",
  "type": "object",
  "required": ["project_id", "style", "story_summary", "characters", "scenes", "pages"],
  "properties": {
    "project_id": { "type": "string", "format": "uuid" },
    "style": {
      "type": "string",
      "enum": ["manga", "western", "cartoon", "cinematic", "childrens_book"]
    },
    "story_summary": {
      "type": "object",
      "required": ["logline", "theme", "arc"],
      "properties": {
        "logline": { "type": "string", "minLength": 10 },
        "theme": { "type": "string", "minLength": 3 },
        "arc": { "type": "string", "minLength": 3 }
      },
      "additionalProperties": false
    },
    "characters": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["character_id", "role", "name"],
        "properties": {
          "character_id": { "type": "string" },
          "role": { "type": "string" },
          "name": { "type": "string" },
          "identity_ref": { "type": "string" }
        },
        "additionalProperties": false
      }
    },
    "scenes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["scene_id", "scene_no", "goal", "start_page", "end_page"],
        "properties": {
          "scene_id": { "type": "string" },
          "scene_no": { "type": "integer", "minimum": 1 },
          "goal": { "type": "string" },
          "start_page": { "type": "integer", "minimum": 1 },
          "end_page": { "type": "integer", "minimum": 1 }
        },
        "additionalProperties": false
      }
    },
    "pages": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "./page.schema.json" }
    }
  },
  "additionalProperties": false
}
